% ------------------------------------------------------------------
% 1) Main listing style for Python blocks
% ------------------------------------------------------------------
\lstdefinestyle{pythonhighlight-style}{
  language      = python,
  inputencoding = utf8,
  extendedchars = true,
  columns       = fullflexible,
  keepspaces    = true,
  showtabs      = true,
  tab=,
  tabsize       = 2,
  basicstyle    = \ttfamily\footnotesize,
  stringstyle   = \color{stringcolour},
  showstringspaces = false,
  alsoletter    = {0123456789\_},   % <-- “_” is now part of identifiers
  otherkeywords = {\%, \}, \{, \&, \|},
  keywordstyle  = \color{keywordcolour}\bfseries,
  emph={and,as,async,await,break,class,continue,def,yield,del,elif,else,%
    except,exec,finally,for,from,global,if,import,in,%
    lambda,not,or,pass,print,raise,return,try,while,assert,with},
  emphstyle     = \color{blue}\bfseries,
  emph={[2]True,False,None},
  emphstyle=[2]\color{keywordcolour},
  emph={[3]object,type,isinstance,copy,deepcopy,zip,enumerate,reversed,list,set,%
    len,dict,tuple,xrange,append,execfile,real,imag,reduce,str,repr},
  emphstyle=[3]\color{commandcolour},
  emph={Exception,NameError,IndexError,SyntaxError,TypeError,ValueError,%
    OverflowError,ZeroDivisionError},
  emphstyle=\color{exceptioncolour}\bfseries,
  morecomment   = [s]{"""}{"""},
  commentstyle  = \color{commentcolour}\slshape,
  frame         = single,
  backgroundcolor=\color{white},
  breakindent   = .5\textwidth,
  breaklines    = true
  % literate      = *\vn@literate   % (may be re‑enabled if needed)
}

% ------------------------------------------------------------------
% 2) For inputting external Python files
% ------------------------------------------------------------------
\newcommand*{\inputpython}[3]{%
  \lstinputlisting[
    firstline=#2,
    lastline=#3,
    firstnumber=#2,
    frame=single,
    breakindent=.5\textwidth,
    breaklines=true,
    style=pythonhighlight-style]{#1}%
}

\NewDocumentCommand\inputpythonfile{moo}{%
  \lstinputlisting[
    firstline=\IfValueTF{#2}{#2}{0},
    lastline=\IfValueTF{#3}{#3}{9999999},
    frame=single,
    breakindent=.5\textwidth,
    breaklines=true,
    style=pythonhighlight-style]{#1}%
}

\lstnewenvironment{python}[2][]{%
  \lst@TestEOLChar{#2}%
  \lstset{style=pythonhighlight-style}%
  \lstset{#1}%
  \csname\@lst @SetFirstNumber\endcsname}{%
  \let\if@nobreak\iffalse%
  \csname\@lst @SaveFirstNumber\endcsname}

% ------------------------------------------------------------------
% 3) Inline‑code style  (inherits Vietnamese literate table)
% ------------------------------------------------------------------
\lstdefinestyle{pythonhighlight-inline-style}{
  style        = pythonhighlight-style,
  basicstyle   = \ttfamily,
  keywordstyle = \color{keywordcolour},
  columns      = fullflexible,
  breaklines   = true,
  breakatwhitespace=false,
  keepspaces   = true,
  prebreak     = \mbox{-},
  literate     =
    {=}{{\literatecolour=}}2
    {-}{{\literatecolour-}}2
    {+}{{\literatecolour+}}2
    {*}{{\literatecolour*}}2
    {**}{{\literatecolour{**}}}3
    {/}{{\literatecolour/}}2
    {//}{{\literatecolour{//}}}2
    {!}{{\literatecolour!}}2
    {[]}{{\literatecolour[]}}2
    {<}{{\literatecolour<}}2
    {<=}{{\literatecolour{<=}}}3
    {>}{{\literatecolour>}}2
    {>=}{{\literatecolour{>=}}}3
    {==}{{\literatecolour{==}}}3
    {!=}{{\literatecolour{!=}}}3
    {+=}{{\literatecolour{+=}}}3
    {-=}{{\literatecolour{-=}}}3
    {*=}{{\literatecolour{*=}}}3
    {/=}{{\literatecolour{/=}}}3
}

% ------------------------------------------------------------------
% 4) Convenience macro for inline Python fragments
% ------------------------------------------------------------------
\newcommand*{\pyth}{\lstinline[style=pythonhighlight-inline-style]}

