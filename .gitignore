# C++ / CMake
build/
*.o
*.so
compile_commands.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Runtime output. Keep one short committed sample of each format as evidence,
# the way the video half keeps its loss-*.log: a reader should see the shape of
# the telemetry without running a flight controller.
mavlink/logs/*.csv
mavlink/logs/*.jsonl
!mavlink/logs/telemetry.sample.csv
!mavlink/logs/telemetry.sample.jsonl
*.mp4
*.mkv

# GST_TRACERS traces: ~700 KB of DEBUG lines each, 5.8 MB for one full sweep.
# measure-latency.sh regenerates them and prints the medians; the raw records
# are not worth a reviewer's bandwidth.
video/results/trace-*.log

# Experiment intermediates: frozen bitstreams and captured frames. Regenerate
# them with make-stream.sh and capture-frames.sh; a 600-picture capture is
# ~380 MB and has no business in git.
*.h264
*.rgb
video/results/frames-*/

# Keep the demo clip and the committed results. The loss-*.log files are the
# receiver's own output, ~1.5 KB each: they are the evidence behind every row of
# the packet-loss tables, and a reader should be able to check the summary line
# without owning a machine.
!docs/assets/demo.mp4
!video/results/latency.md
!video/results/packet-loss.md
!video/results/img/*.png

# LaTeX build artifacts (docs/Report). The .tex/.bib sources, the .cls/.sty
# template files and the final PDF are committed; everything below is
# regenerated by a pdflatex/biber run and has no business in git.
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.toc
*.listing
*.run.xml
*.synctex.gz
*-blx.bib
# scoped: video/results keeps its loss-*.log evidence, so only the report's log
docs/Report/*.log

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
